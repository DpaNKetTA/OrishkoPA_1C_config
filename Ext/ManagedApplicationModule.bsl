//Задание1_2
Процедура ВывестиИзмененнуюДату()      
	Тек_Дата = ТекущаяДата();
	Сообщить ("Текущая дата: " + Тек_Дата);
	
	Новая_дата = ДобавитьМесяц(Тек_Дата, 1);
	Сообщить("После прибавления месяца: " + Новая_дата);
КонецПроцедуры              

//Задание2
Процедура ОпределитьТипЧисла()       
	ГСЧ = Новый ГенераторСлучайныхЧисел;
	Случ_число = ГСЧ.СлучайноеЧисло(0, 20) - 10;
	
	Если Случ_число > 0 Тогда 
		Тип_числа = "Положительное";
	ИначеЕсли Случ_число = 0 Тогда
		Тип_числа = "Ноль";
	Иначе 
		Тип_числа = "Отрицательное";
	КонецЕсли;    
	
	Сообщить("Число: " + Случ_число + ". " + Тип_числа);
Конецпроцедуры           

//Функция для задания 3
Функция СформироватьМассив()
	ГСЧ = Новый ГенераторСлучайныхЧисел;
	Массив = Новый Массив;
	
	Для Счетчик = 1 По 15 Цикл
		Число = ГСЧ.СлучайноеЧисло(0,20) - 10;
		
		Массив.Добавить(Число);
	КонецЦикла;   
	
	Возврат Массив;
КонецФункции        
//Вывод для задания 3
Процедура Задание3()  
	Массив_рез = СформироватьМассив();  
	
	СтрокаВывода = СтрСоединить(Массив_рез, "; ");
	Сообщить(СтрокаВывода);
КонецПроцедуры

