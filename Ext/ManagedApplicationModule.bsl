Процедура Задание4()          
	МояСтруктура = Новый Структура;
	
	МояСтруктура.Вставить("Это_ключ1", "Первый элемент");
	МояСтруктура.Вставить("Это_ключ2", "Второй элемент");  
	МояСтруктура.Вставить("Это_ключ3", "Третий элемент");      
	
	Для каждого эл из МояСтруктура Цикл      
		Сообщить(эл.Ключ + ": " + эл.Значение);
	КонецЦикла
КонецПроцедуры

//Задание5
Процедура ПроверкаДелимости()  
	n = 19;
	sum = 0;
	i = 0;
	
	Пока i <=n Цикл         
		Если i%5 = 0 тогда
			sum = sum+i; 
		КонецЕсли;
		i = i + 1;
	КонецЦикла;      
	Сообщить("Сумма чисел делющихся на 5 от 0 до " + n + " равна: " + sum);
	
	
КонецПроцедуры






